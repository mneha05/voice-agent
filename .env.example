# ==========================================================================
#  Voice Agent — environment configuration
#  Copy this file to `.env` and fill in your keys.
# ==========================================================================

# --- Deepgram (required) --------------------------------------------------
# Get a key at https://console.deepgram.com  (new accounts get free credit)
DEEPGRAM_API_KEY=

# STT: streaming speech-to-text model
DG_STT_MODEL=nova-3
DG_STT_LANGUAGE=en
# Endpointing (ms of silence before Deepgram flags end-of-speech). Lower = snappier
# turns, higher = fewer false cut-offs. 300 is a good low-latency default.
DG_ENDPOINTING_MS=300
# Utterance-end fallback (ms). Fires an end-of-turn even if endpointing missed it.
DG_UTTERANCE_END_MS=1000

# TTS: streaming text-to-speech voice
# Voices: aura-2-thalia-en, aura-2-andromeda-en, aura-2-helena-en, aura-asteria-en ...
DG_TTS_MODEL=aura-2-thalia-en

# --- LLM (required) -------------------------------------------------------
# Which brain answers. "anthropic" or "openai".
LLM_PROVIDER=anthropic

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001     # fast + cheap = low latency

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# System persona for the agent.
SYSTEM_PROMPT=You are a warm, concise voice assistant. Keep replies to one or two short sentences unless asked for detail. You are being spoken to out loud, so never use markdown, lists, or emojis.

# --- Server ---------------------------------------------------------------
HOST=127.0.0.1
PORT=8000
